# PharmaSim Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# BACKEND (FastAPI)
# =============================================================================

# Allowed frontend origin for CORS (optional, defaults to localhost:3000)
FRONTEND_URL=http://localhost:3000

# =============================================================================
# FRONTEND (Next.js)
# =============================================================================

# URL of the FastAPI backend (optional, defaults to http://127.0.0.1:8000)
BACKEND_URL=http://127.0.0.1:8000

# =============================================================================
# GEMINI AI (for drug summaries and SMILES name resolution)
# =============================================================================

# Google Gemini API key (required for AI summaries, falls back to template if missing)
GEMINI_API_KEY=

# Preferred Gemini model (optional, defaults to gemini-2.0-flash)
# Options: gemini-2.0-flash, gemini-flash-latest, gemini-2.5-flash
GEMINI_MODEL=

# =============================================================================
# ML FEATURES
# =============================================================================

# Enable ADMET-AI integration for absorption/metabolism predictions
# Set to "true" or "1" to enable (optional, disabled by default)
PHARMASIM_USE_ADMET_AI=false
